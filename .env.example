#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

# URL base del sitio. Debe coincidir con el Alias/DocumentRoot de Apache.
app.baseURL = 'http://localhost/Proyecto-CVA-Muebles/'

SHOPPING_CART_ENABLED = true
WHATSAPP_NUMBER = 5493794098511

#--------------------------------------------------------------------
# SMTP EMAIL CONFIG
#--------------------------------------------------------------------
# Usar una "Contraseña de aplicación" de Google, no la contraseña real de la cuenta.

email.protocol = 'smtp'
email.SMTPHost = 'smtp.gmail.com'
email.SMTPUser = 'tucorreo@gmail.com'
email.SMTPPass = 'tu_password_de_16_letras'
email.SMTPPort = 465
email.SMTPCrypto = 'ssl'
email.mailType = 'html'
email.charset  = 'utf-8'
email.CRLF = "\r\n"
email.newline = "\r\n"
email.fromEmail = 'tucorreo@gmail.com'
email.fromName = 'CVA Muebles'

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = cva_muebles
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------
# Generar una clave propia: php spark key:generate
# NUNCA reusar esta clave de ejemplo ni commitear la real.

encryption.key =
