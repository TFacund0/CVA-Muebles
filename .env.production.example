#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
# En el servidor de producción real (NO en tu .env local de desarrollo).

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
# baseURL con HTTPS: forceGlobalSecureRequests (app/Config/App.php) va a
# redirigir todo a HTTPS, así que el sitio debe tener certificado válido
# antes de desplegar con estos valores.

app.baseURL = 'https://tu-dominio-real.com/'

SHOPPING_CART_ENABLED = true
WHATSAPP_NUMBER = 5493794098511

#--------------------------------------------------------------------
# SMTP EMAIL CONFIG
#--------------------------------------------------------------------
# Usar una "Contraseña de aplicación" de Google, no la contraseña real de la cuenta.
# Generar una nueva y distinta a la que se usa en desarrollo.

email.protocol = 'smtp'
email.SMTPHost = 'smtp.gmail.com'
email.SMTPUser = 'tucorreo@gmail.com'
email.SMTPPass = 'tu_password_de_16_letras'
email.SMTPPort = 465
email.SMTPCrypto = 'ssl'
email.mailType = 'html'
email.charset  = 'utf-8'
email.CRLF = "\r\n"
email.newline = "\r\n"
email.fromEmail = 'tucorreo@gmail.com'
email.fromName = 'CVA Muebles'

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = cva_muebles
database.default.username = tu_usuario_de_bd
database.default.password = tu_password_de_bd
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------
# Generar una clave propia y distinta a la de desarrollo: php spark key:generate
# NUNCA reusar esta clave de ejemplo ni commitear la real.

encryption.key =
